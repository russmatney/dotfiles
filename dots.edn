{;; Symlink manifest — source of truth for all dotfile links.
 ;; Managed by dots.bb. Run `bb dots link` to apply, `bb dots status` to check.
 ;;
 ;; :from  — path relative to this repo root
 ;; :to    — destination path (~/ expanded to $HOME)
 ;;
 ;; Links are applied in order. Machine-specific links are merged on top.

 :links
 [{:from "config/foot"                       :to "~/.config/foot"}
  {:from "config/alacritty"                  :to "~/.config/alacritty"}
  {:from "config/nvim"                       :to "~/.config/nvim"}
  {:from "config/nvim.fnl"                   :to "~/.config/nvim.fnl"}
  {:from "config/emacs/doom"                 :to "~/.config/doom"}
  {:from "config/emacs/applications"         :to "~/.local/share/applications"
   :link-contents true}
  {:from "config/hypr"                       :to "~/.config/hypr"}
  {:from "config/tmux/powerline"             :to "~/.config/powerline"}
  {:from "config/tmux/systemd/user"          :to "~/.config/systemd/user"
   :link-contents true}
  {:from "home/.tmux.conf"                   :to "~/.tmux.conf"}
  {:from "home/.gitconfig"                   :to "~/.gitconfig"}
  {:from "scripts"                           :to "~/.local/bin" :link-contents true}]

 :machines
 {"yoshi"    [{:from "config/hypr/machines/yoshi/monitors.conf"
               :to   "~/.config/hypr/monitors-machine.conf"}
              {:from "config/hypr/machines/yoshi/overrides.conf"
               :to   "~/.config/hypr/overrides-machine.conf"}]
  "brain"    [{:from "config/hypr/machines/brain/monitors.conf"
               :to   "~/.config/hypr/monitors-machine.conf"}
              {:from "config/hypr/machines/brain/overrides.conf"
               :to   "~/.config/hypr/overrides-machine.conf"}]
  "walt"     [{:from "config/hypr/machines/walt/monitors.conf"
               :to   "~/.config/hypr/monitors-machine.conf"}
              {:from "config/hypr/machines/walt/overrides.conf"
               :to   "~/.config/hypr/overrides-machine.conf"}]
  "wordnerd" [{:from "config/hypr/machines/wordnerd/monitors.conf"
               :to   "~/.config/hypr/monitors-machine.conf"}
              {:from "config/hypr/machines/wordnerd/overrides.conf"
               :to   "~/.config/hypr/overrides-machine.conf"}]}}
